# =============================================================================
# GridWeaver — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# =============================================================================

# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Application port
APP_PORT=8080

# PostgreSQL
POSTGRES_DB=gridweaverdb
POSTGRES_USER=gridweaver
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (use a 512-bit / 64+ character random string)
JWT_SECRET=change_me_to_a_very_long_random_512_bit_secret_key_for_production_use
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000
JWT_ISSUER=gridweaver

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.gridweaver.com

# Adminer (dev only)
ADMINER_PORT=8081
